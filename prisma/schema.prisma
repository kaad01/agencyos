generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  AT_RISK
  DONE
  ARCHIVED
}

enum TicketStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CustomerHealth {
  EXCELLENT
  HEALTHY
  NEEDS_CARE
  NEW
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships   Membership[]
  ledProjects   Project[]     @relation("ProjectLead")
  assignedTickets Ticket[]    @relation("TicketAssignee")
  reportedTickets Ticket[]    @relation("TicketReporter")
  timeEntries   TimeEntry[]

  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  customers   Customer[]
  projects    Project[]
  tickets     Ticket[]
  timeEntries TimeEntry[]
  invites     Invite[]
}

model Membership {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  hourlyRate  Decimal?      @db.Decimal(10, 2)
  capacityHoursPerWeek Decimal? @db.Decimal(6, 2)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectMemberships ProjectMember[]

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Customer {
  id             String         @id @default(cuid())
  workspaceId    String
  name           String
  segment        String?
  ownerName      String?
  health         CustomerHealth @default(NEW)
  revenueTarget  Decimal        @default(0) @db.Decimal(12, 2)
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@index([workspaceId])
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  customerId  String
  leadId      String?
  name        String
  summary     String?       @db.Text
  status      ProjectStatus @default(PLANNING)
  budget      Decimal       @default(0) @db.Decimal(12, 2)
  hourlyRate  Decimal       @default(0) @db.Decimal(10, 2)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lead      User?     @relation("ProjectLead", fields: [leadId], references: [id], onDelete: SetNull)
  members   ProjectMember[]
  tickets   Ticket[]
  timeEntries TimeEntry[]

  @@index([workspaceId])
  @@index([customerId])
  @@index([leadId])
}

model ProjectMember {
  id          String        @id @default(cuid())
  projectId   String
  membershipId String
  role        WorkspaceRole @default(MEMBER)
  hourlyRateOverride Decimal? @db.Decimal(10, 2)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([projectId, membershipId])
  @@index([membershipId])
}

model Ticket {
  id          String         @id @default(cuid())
  workspaceId String
  projectId   String
  title       String
  description String?        @db.Text
  status      TicketStatus   @default(BACKLOG)
  priority    TicketPriority @default(MEDIUM)
  assigneeId  String?
  reporterId  String?
  estimateMinutes Int        @default(0)
  dueDate     DateTime?
  position    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee  User?     @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter  User?     @relation("TicketReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  timeEntries TimeEntry[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([assigneeId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String
  ticketId    String?
  userId      String
  date        DateTime
  durationMinutes Int
  description String?  @db.Text
  billable    Boolean  @default(true)
  hourlyRateSnapshot Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticket    Ticket?   @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@index([ticketId])
  @@index([userId])
  @@index([date])
}

model Invite {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(MEMBER)
  token       String        @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}
